# --- RPC endpoints -----------------------------------------------------------
# Sepolia RPC (Alchemy/Infura/etc). A public RPC fallback is used if left blank.
NEXT_PUBLIC_SEPOLIA_RPC_URL=
# Ethereum mainnet RPC (read-only browse + both-network address display).
NEXT_PUBLIC_MAINNET_RPC_URL=

# --- Wallet ------------------------------------------------------------------
# WalletConnect project id (optional; enables the WalletConnect connector).
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# --- Zama relayer (Sepolia testnet) ------------------------------------------
NEXT_PUBLIC_RELAYER_URL=https://relayer.testnet.zama.cloud

# --- Privy (wallet connect) — get an app id at https://dashboard.privy.io ---
NEXT_PUBLIC_PRIVY_APP_ID=

# --- Gas drip faucet (SERVER-ONLY — never prefix with NEXT_PUBLIC) ---
# Private key of a Sepolia wallet funded with test ETH. New embedded (email/social)
# wallets get a small drip so they can pay for faucet/wrap/unwrap. Blank = disabled.
DRIP_PRIVATE_KEY=
